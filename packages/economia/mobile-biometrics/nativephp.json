{
    "namespace": "MobileBiometrics",
    "bridge_functions": [
        {
            "name": "Biometric.Prompt",
            "android": "com.economia.biometrics.BiometricFunctions.Prompt",
            "android_params": ["activity"],
            "description": "Muestra el prompt biométrico (huella/face) o credencial del dispositivo"
        }
    ],
    "android": {
        "min_version": 23,
        "permissions": [
            "android.permission.USE_BIOMETRIC"
        ],
        "dependencies": {
            "implementation": [
                "androidx.biometric:biometric:1.1.0"
            ]
        }
    },
    "ios": {
        "min_version": "18.2"
    },
    "events": [
        "Native\\Mobile\\Events\\Biometric\\Completed"
    ]
}
